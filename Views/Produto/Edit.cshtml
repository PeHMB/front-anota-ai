@model anotaai.Models.ProdutoModel
<div class="bg-white m-6 p-6 rounded-2xl shadow-lg border border-gray-100">
  <div class="max-w-md mx-auto mt-8">
    <h1 class="text-2xl font-bold mb-6">Editar Produto</h1>

    <form asp-action="Edit" method="post" class="space-y-4">
      <input type="hidden" asp-for="Id" />

      <div>
        <label asp-for="Nome" class="block font-medium">Nome</label>
        <input asp-for="Nome" class="border rounded w-full px-3 py-2" />
        <span asp-validation-for="Nome" class="text-red-500 text-sm"></span>
      </div>

      <div>
        <label asp-for="Descricao" class="block font-medium">Descrição</label>
        <input asp-for="Descricao" class="border rounded w-full px-3 py-2" />
        <span asp-validation-for="Descricao" class="text-red-500 text-sm"></span>
      </div>

      <div>
        <label asp-for="Preco" class="block font-medium">Preço</label>
        <input asp-for="Preco" type="number" step="0.01"
               class="border rounded w-full px-3 py-2" />
        <span asp-validation-for="Preco" class="text-red-500 text-sm"></span>
      </div>

      <div class="flex gap-4 pt-4">
        <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
          Salvar
        </button>
        <a asp-action="Index" class="px-4 py-2 border rounded hover:bg-gray-100">
          Cancelar
        </a>
      </div>
    </form>
  </div>
</div>
