@model IEnumerable<anotaai.Models.ProdutoModel>
  <div class="bg-white m-6 p-6 rounded-2xl shadow-lg border border-gray-100">
    <h1 class="font-bold text-xl mb-6">Produtos</h1>

    <table class="table">
      <thead>
	<tr class="text-gray-500 border-b">
	  <th>Nome</th>
	  <th>Descrição</th>
	  <th>Preço</th>
	  <th>Ação</th>
	</tr>
      </thead>
      <tbody>
	@foreach(var produto in Model)
	{
	<tr class="hover:bg-gray-50">
	  <td>@produto.Nome</td>
	  <td>@produto.Descricao</td>
	  <td>@produto.Preco</td>
	  <td>Editar e deletar </td>
	</tr>
	  }
      </tbody>
    </table>

  </div>
