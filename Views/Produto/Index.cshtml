@model IEnumerable<anotaai.Models.ProdutoModel>
  <div class="bg-white m-6 p-6 rounded-2xl shadow-lg border border-gray-100">
    <h1 class="font-bold text-xl mb-6">Produtos</h1>

    <table class="table">
      <thead>
	<tr class="text-gray-500 border-b">
	  <th>Nome</th>
	  <th>Descrição</th>
	  <th>Preço</th>
	  <th>Ação</th>
	</tr>
      </thead>
      <tbody>
	@foreach(var produto in Model)
	{
	<tr class="hover:bg-gray-50">
	  <td>@produto.Nome</td>
	  <td>@produto.Descricao</td>
	  <td>@produto.Preco</td>
	  <td>
	    <a asp-controller="Produto" asp-action="Edit" asp-route-id="@produto.Id"
	       class="text-blue-600 hover:underline">Editar</a>
	    <span class="text-gray-300">|</span>
              <button onclick="deletarProduto(@produto.Id)"
                      class="text-red-600 hover:underline cursor-pointer">
		Deletar
              </button>
	  </td>
	</tr>
	      }
      </tbody>
    </table>

  </div>
  
  <script>
   function deletarProduto(id) {
     if (!confirm('Tem certeza que deseja deletar este produto?')) {
       return;
              }

     fetch(`/api/produtos/${id}`, {
       method: 'DELETE'
              })
       .then(response => {
         if (response.ok) {
           location.reload();
              } else {
                alert('Erro ao deletar: ' + response.status);
              }
              })
       .catch(error => {
         console.error('Erro:', error);
         alert('Erro de conexão ao deletar.');
              });
	      }
  </script>



